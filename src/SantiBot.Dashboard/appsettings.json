{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // JWT secret for dashboard auth tokens. CHANGE THIS in production!
  "Jwt": {
    "Key": ""
  },

  // Discord OAuth2 credentials for dashboard login.
  // Get these from https://discord.com/developers/applications -> your bot -> OAuth2
  // Add redirect URI: http://localhost:5000/api/auth/callback
  "Discord": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "http://YOUR_SERVER_IP:5000/api/auth/callback"
  },

  // Frontend URL the dashboard API redirects to after login
  "Dashboard": {
    "FrontendUrl": "http://YOUR_SERVER_IP:3000"
  }
}
